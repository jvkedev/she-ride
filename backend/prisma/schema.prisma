generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  PENDING
  RIDER
  CAPTAIN
  ADMIN
  SECURITY
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

/// Organizational department (metadata only — not used for authorization).
enum AdminDepartment {
  OPERATIONS
  SAFETY
  SUPPORT
  FINANCE
  TECHNOLOGY
  MANAGEMENT
}

/// Job title within the organization (metadata only).
enum AdminJobTitle {
  ADMINISTRATOR
  OPERATIONS_MANAGER
  SAFETY_MANAGER
  SUPPORT_EXECUTIVE
  FINANCE_OFFICER
  TECHNICAL_ADMINISTRATOR
}

/// Permission level for admin users (separate from User.role which must stay ADMIN for JWT).
enum AdminPermissionRole {
  SUPER_ADMIN
  ADMIN
}

enum AccountStatus {
  ACTIVE
  BLOCKED
  PENDING
}

enum OnboardingStatus {
  PENDING
  RIDER_COMPLETED
  CAPTAIN_COMPLETED
}

enum RidePreference {
  QUIET
  CHATTY
  WOMEN_ONLY
  PET_FRIENDLY
}

enum VehicleType {
  BIKE
  AUTO
  CAR
  SUV
}

enum DocumentStatus {
  PENDING
  APPROVED
  REJECTED
}

enum CaptainDocumentType {
  DRIVING_LICENSE
  VEHICLE_RC
  VEHICLE_INSURANCE
  GOVERNMENT_ID
}

enum CaptainVerificationStatus {
  NOT_UPLOADED
  PENDING_REVIEW
  APPROVED
  REJECTED
}

enum RideStatus {
  SEARCHING
  ACCEPTED
  ARRIVING
  IN_PROGRESS
  COMPLETED
  CANCELED
}

enum PaymentMethod {
  CASH
  CARD
  UPI
  WALLET
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

enum CaptainReportCategory {
  UNSAFE_DRIVING
  HARASSMENT
  INAPPROPRIATE_BEHAVIOR
  VEHICLE_ISSUE
  ROUTE_ISSUE
  FRAUD_OVERCHARGING
  LATE_ARRIVAL
  OTHER
}

enum CaptainReportStatus {
  OPEN
  UNDER_REVIEW
  RESOLVED
  DISMISSED
}

enum SupportTicketCategory {
  RIDE_ISSUE
  PAYMENT
  ACCOUNT
  SAFETY
  APP_BUG
  OTHER
}

enum SupportTicketStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum OtpType {
  PHONE_VERIFICATION
  LOGIN
  PASSWORD_RESET
  RIDE_START
}

enum TransactionType {
  TOPUP
  RIDE_DEDUCTION
  REFUND
}

enum TransactionStatus {
  PENDING
  SUCCESS
  FAILED
}

enum SosStatus {
  ACTIVE
  RESOLVED
  FALSE_ALARM
}

enum SosTriggerType {
  BUTTON_PRESS
  AUTO_DETECTED
  VOICE
}

enum FraudType {
  FAKE_PAYMENT
  PROMO_ABUSE
  ACCOUNT_TAKEOVER
  ROUTE_MANIPULATION
  FAKE_RATING
  IDENTITY_FRAUD
  MULTIPLE_ACCOUNTS
}

enum FraudRiskLevel {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum FraudStatus {
  OPEN
  UNDER_REVIEW
  RESOLVED
  FALSE_POSITIVE
}

enum IncidentType {
  HARASSMENT
  ASSAULT
  THEFT
  ACCIDENT
  UNSAFE_DRIVING
  ROUTE_DEVIATION
  OTHER
}

enum IncidentSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum IncidentStatus {
  OPEN
  INVESTIGATING
  RESOLVED
  CLOSED
  REJECTED
}

enum IncidentPriority {
  P1 // Critical — respond in 2 min
  P2 // High — respond in 10 min
  P3 // Medium — respond in 1 hour
  P4 // Low — respond in 24 hours
}

enum IncidentSource {
  APP
  SOS_AUTO
  ADMIN_MANUAL
  SYSTEM
}

enum RiskLevel {
  LOW
  MEDIUM
  HIGH
}

enum EmergencyType {
  POLICE
  AMBULANCE
  FIRE
}

enum EmergencyStatus {
  DISPATCHED
  ON_THE_WAY
  ARRIVED
  RESOLVED
}

enum AuditAction {
  SOS_CREATED
  SOS_RESOLVED
  FRAUD_FLAGGED
  FRAUD_RESOLVED
  USER_BLOCKED
  USER_UNBLOCKED
  DRIVER_VERIFIED
  DRIVER_REJECTED
  INCIDENT_CREATED
  INCIDENT_RESOLVED
  RISK_ZONE_ADDED
  RISK_ZONE_REMOVED
  EMERGENCY_DISPATCHED
  INCIDENT_ASSIGNED
  INCIDENT_STATUS_CHANGED
  INCIDENT_NOTE_ADDED
}

model User {
  id String @id @default(cuid())

  fullName    String
  email       String @unique
  phoneNumber String @unique
  password    String

  role UserRole @default(PENDING)

  onboardingStatus OnboardingStatus @default(PENDING)

  accountStatus   AccountStatus @default(PENDING)
  isPhoneVerified Boolean       @default(false)

  otps Otp[]

  refreshToken String?

  rider   Rider?
  captain Captain?

  admin Admin?

  securityStaff SecurityStaff?

  fraudCases        FraudCase[]
  fraudSignals      FraudSignal[]
  suspiciousAccount SuspiciousAccount?
  reportedIncidents Incident[]         @relation("IncidentReporter")

  assignedIncidents Incident[]         @relation("IncidentAssignee")
  incidentNotes     IncidentNote[]     @relation("NoteAuthor")
  uploadedEvidence  IncidentEvidence[] @relation("EvidenceUploader")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}

model Rider {
  id String @id @default(uuid())

  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  profileImage String?

  gender      Gender?
  dateOfBirth DateTime?

  emergencyContactName  String?
  emergencyContactPhone String?

  ridePreference RidePreference?

  rides Ride[]

  safetyAlertEnabled Boolean @default(true)
  shareLiveLocation  Boolean @default(true)

  sosAlerts SosAlert[]

  captainReports CaptainReport[]
  supportTickets SupportTicket[]

  defaultPaymentMethod PaymentMethod @default(CASH)
  notifyRideUpdates    Boolean       @default(true)

  totalRides     Int @default(0)
  cancelledRides Int @default(0)

  averageRating Float @default(5)

  lastRideAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Captain {
  id String @id @default(cuid())

  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  profileImage String?

  gender      Gender?
  dateOfBirth DateTime?

  isVerified Boolean @default(false)
  isOnline   Boolean @default(false)

  rides Ride[]
  sosAlerts SosAlert[]

  rating Float @default(5)

  totalTrips Int @default(0)

  currentLatitude  Float?
  currentLongitude Float?

  behaviorFlags DriverBehaviorFlag[]

  captainReports CaptainReport[]

  vehicle  Vehicle?
  document CaptainDocument?

  verifiedAt DateTime?

  emergencyContactName  String?
  emergencyContactPhone String?
  safetyAlertEnabled    Boolean @default(true)
  notifyRequestAlerts   Boolean @default(true)
  shareLiveLocation     Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isOnline])
  @@map("captains")
}

model CaptainDocument {
  id String @id @default(cuid())

  captainId String  @unique
  captain   Captain @relation(fields: [captainId], references: [id], onDelete: Cascade)

  aadhaarNumber        String? @unique
  drivingLicenseNumber String? @unique

  aadhaarFrontImage String?
  aadhaarBackImage  String?

  drivingLicenseImage String?

  rcImage String?

  selfieImage String?

  documentStatus DocumentStatus @default(PENDING)

  rejectionReason String?

  uploadedAt DateTime  @default(now())
  verifiedAt DateTime?

  items CaptainDocumentItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("captain_documents")
}

model CaptainDocumentItem {
  id String @id @default(cuid())

  documentId String
  document   CaptainDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)

  documentType       CaptainDocumentType
  documentUrl        String?
  uploadedAt         DateTime?
  verificationStatus CaptainVerificationStatus @default(NOT_UPLOADED)
  rejectionReason    String?
  reviewedBy         String?
  reviewedAt         DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([documentId, documentType])
  @@index([verificationStatus])
  @@map("captain_document_items")
}

model Vehicle {
  id String @id @default(cuid())

  captainId String  @unique
  captain   Captain @relation(fields: [captainId], references: [id], onDelete: Cascade)

  vehicleType VehicleType

  brand String
  model String
  color String

  vehicleNumber String @unique

  seatCapacity Int

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("vehicles")
}

model Admin {
  id String @id @default(cuid())

  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  profileImage String?

  gender      Gender?
  dateOfBirth DateTime?

  department     AdminDepartment?
  jobTitle       AdminJobTitle?
  permissionRole AdminPermissionRole @default(ADMIN)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("admins")
}

model SecurityStaff {
  id String @id @default(cuid())

  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  profileImage String?

  gender      Gender?
  dateOfBirth DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("security_staff")
}

model Ride {
  id String @id @default(cuid())

  riderId String
  rider   Rider  @relation(fields: [riderId], references: [id], onDelete: Cascade)

  captainId String?
  captain   Captain? @relation(fields: [captainId], references: [id])

  pickupAddress String
  dropAddress   String

  pickupLatitude  Float
  pickupLongitude Float

  dropLatitude  Float
  dropLongitude Float

  distanceInKm  Float?
  estimatedFare Float?
  finalFare     Float?

  sosAlerts     SosAlert[]
  fraudCases    FraudCase[]
  incidents     Incident[]
  behaviorFlags DriverBehaviorFlag[]
  captainReports CaptainReport[]
  supportTickets SupportTicket[]

  vehicleType VehicleType

  paymentMethod PaymentMethod @default(CASH)

  paymentStatus PaymentStatus @default(PENDING)

  startedAt   DateTime?
  completedAt DateTime?
  cancelledAt DateTime?

  status RideStatus @default(SEARCHING)

  acceptedAt DateTime?
  arrivedAt  DateTime?

  cancelledBy        UserRole?
  cancellationReason String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  otps      Otp[]

  @@index([riderId])
  @@index([captainId])
  @@index([status])
  @@map("rides")
}

model Otp {
  id String @id @default(cuid())

  phoneNumber String

  code String

  type OtpType

  expiresAt DateTime

  isUsed Boolean @default(false)

  userId String?
  user   User?   @relation(fields: [userId], references: [id], onDelete: Cascade)

  rideId String?
  ride   Ride?   @relation(fields: [rideId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([phoneNumber])
  @@index([code])
  @@map("otps")
}

model SosAlert {
  id String @id @default(cuid())

  riderId String
  rider   Rider  @relation(fields: [riderId], references: [id], onDelete: Cascade)

  rideId String?
  ride   Ride?   @relation(fields: [rideId], references: [id])

  captainId String?
  captain   Captain? @relation(fields: [captainId], references: [id])

  triggerType SosTriggerType
  status      SosStatus      @default(ACTIVE)

  latitude  Float
  longitude Float
  address   String?

  handledBy      String?
  handledAt      DateTime?
  resolvedAt     DateTime?
  resolutionNote String?

  locationSnapshots SosLocationSnapshot[]
  emergencyServices EmergencyDispatch[]
  auditLogs         AuditLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([riderId])
  @@index([status])
  @@map("sos_alerts")
}

model SosLocationSnapshot {
  id String @id @default(cuid())

  sosAlertId String
  sosAlert   SosAlert @relation(fields: [sosAlertId], references: [id], onDelete: Cascade)

  latitude   Float
  longitude  Float
  capturedAt DateTime @default(now())

  @@index([sosAlertId])
  @@map("sos_location_snapshots")
}

model FraudCase {
  id String @id @default(cuid())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  rideId String?
  ride   Ride?   @relation(fields: [rideId], references: [id])

  fraudType  FraudType
  riskLevel  FraudRiskLevel
  fraudScore Float

  status FraudStatus @default(OPEN)

  evidence       Json?
  description    String?
  reviewedBy     String?
  reviewedAt     DateTime?
  resolvedAt     DateTime?
  resolutionNote String?

  auditLogs AuditLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([status])
  @@index([riskLevel])
  @@map("fraud_cases")
}

model FraudSignal {
  id String @id @default(cuid())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  signalType String
  payload    Json
  score      Float

  createdAt DateTime @default(now())

  @@index([userId])
  @@map("fraud_signals")
}

model Incident {
  id             String @id @default(cuid())
  incidentNumber String @unique

  reportedBy   String
  user         User     @relation("IncidentReporter", fields: [reportedBy], references: [id])
  reporterRole UserRole

  rideId String?
  ride   Ride?   @relation(fields: [rideId], references: [id])

  incidentType IncidentType
  severity     IncidentSeverity
  priority     IncidentPriority @default(P3)
  source       IncidentSource   @default(APP)
  status       IncidentStatus   @default(OPEN)

  description String
  evidence    IncidentEvidence[]

  latitude  Float?
  longitude Float?
  address   String?

  assignedTo   String?
  assignedUser User?     @relation("IncidentAssignee", fields: [assignedTo], references: [id])
  assignedAt   DateTime?

  resolvedAt DateTime?
  resolvedBy String?
  closedAt   DateTime?

  firstResponseAt DateTime?
  slaDeadline     DateTime?
  slaBreachedAt   DateTime?

  duplicateOf    String?
  parentIncident Incident?  @relation("IncidentDuplicates", fields: [duplicateOf], references: [id])
  duplicates     Incident[] @relation("IncidentDuplicates")

  deletedAt DateTime?
  tags      String[]

  notes     IncidentNote[]
  auditLogs AuditLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([severity])
  @@index([priority])
  @@index([severity, createdAt])
  @@index([reportedBy])
  @@index([assignedTo])
  @@index([incidentNumber])
  @@map("incidents")
}

model IncidentNote {
  id String @id @default(cuid())

  incidentId String
  incident   Incident @relation(fields: [incidentId], references: [id], onDelete: Cascade)

  authorId String
  author   User   @relation("NoteAuthor", fields: [authorId], references: [id])

  content    String
  isInternal Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([incidentId])
  @@map("incident_notes")
}

model IncidentEvidence {
  id String @id @default(cuid())

  incidentId String
  incident   Incident @relation(fields: [incidentId], references: [id], onDelete: Cascade)

  uploadedBy String
  uploader   User   @relation("EvidenceUploader", fields: [uploadedBy], references: [id])

  fileUrl    String
  fileType   String
  fileName   String
  fileSizeKb Int
  fileHash   String

  uploadedAt DateTime @default(now())

  @@index([incidentId])
  @@map("incident_evidence")
}

model SuspiciousAccount {
  id String @id @default(cuid())

  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  reasons   String[]
  riskScore Float

  flaggedBy  String?
  flaggedAt  DateTime  @default(now())
  reviewedBy String?
  reviewedAt DateTime?

  isResolved Boolean   @default(false)
  resolvedAt DateTime?
  notes      String?

  auditLogs AuditLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isResolved])
  @@map("suspicious_accounts")
}

model RiskZone {
  id String @id @default(cuid())

  name      String
  riskLevel RiskLevel

  centerLatitude  Float
  centerLongitude Float
  radiusInMeters  Float

  description String?
  isActive    Boolean @default(true)
  createdBy   String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive])
  @@map("risk_zones")
}

model DriverBehaviorFlag {
  id String @id @default(cuid())

  captainId String
  captain   Captain @relation(fields: [captainId], references: [id], onDelete: Cascade)

  rideId String?
  ride   Ride?   @relation(fields: [rideId], references: [id])

  flagType    String
  severity    String
  description String?

  latitude   Float?
  longitude  Float?
  detectedAt DateTime @default(now())

  isReviewed Boolean   @default(false)
  reviewedBy String?
  reviewedAt DateTime?

  @@index([captainId])
  @@index([isReviewed])
  @@map("driver_behavior_flags")
}

model AuditLog {
  id          String      @id @default(cuid())
  performedBy String
  action      AuditAction

  sosAlertId String?
  sosAlert   SosAlert? @relation(fields: [sosAlertId], references: [id])

  fraudCaseId String?
  fraudCase   FraudCase? @relation(fields: [fraudCaseId], references: [id])

  incidentId String?
  incident   Incident? @relation(fields: [incidentId], references: [id])

  ipAddress    String?
  userAgent    String?
  previousData Json?
  newData      Json?
  channel      String?

  suspiciousAccountId String?
  suspiciousAccount   SuspiciousAccount? @relation(fields: [suspiciousAccountId], references: [id])

  metadata  Json?
  createdAt DateTime @default(now())

  @@index([performedBy])
  @@index([action])
  @@map("audit_logs")
}

model EmergencyDispatch {
  id String @id @default(cuid())

  sosAlertId String
  sosAlert   SosAlert @relation(fields: [sosAlertId], references: [id], onDelete: Cascade)

  emergencyType EmergencyType
  status        EmergencyStatus @default(DISPATCHED)

  dispatchedBy String
  dispatchedAt DateTime @default(now())

  arrivedAt  DateTime?
  resolvedAt DateTime?
  notes      String?

  @@index([sosAlertId])
  @@map("emergency_dispatches")
}

model CaptainReport {
  id String @id @default(cuid())

  rideId String
  ride   Ride @relation(fields: [rideId], references: [id], onDelete: Cascade)

  riderId String
  rider   Rider @relation(fields: [riderId], references: [id], onDelete: Cascade)

  captainId String
  captain   Captain @relation(fields: [captainId], references: [id], onDelete: Cascade)

  category    CaptainReportCategory
  description String?
  imageUrl    String?
  status      CaptainReportStatus   @default(OPEN)
  adminNote   String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([rideId, riderId])
  @@index([captainId])
  @@index([status])
  @@map("captain_reports")
}

model SupportTicket {
  id String @id @default(cuid())

  riderId String
  rider   Rider @relation(fields: [riderId], references: [id], onDelete: Cascade)

  rideId String?
  ride   Ride?   @relation(fields: [rideId], references: [id], onDelete: SetNull)

  category SupportTicketCategory
  subject  String
  description String
  status   SupportTicketStatus @default(OPEN)

  adminResponse String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([riderId])
  @@index([status])
  @@map("support_tickets")
}
